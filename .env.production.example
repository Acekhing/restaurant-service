# Copy to .env.production. deploy/deploy.sh links .env -> .env.production so docker compose loads these vars.
# ─── PostgreSQL ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ─── HTTP ───
# Host port for nginx (container still listens on 80). Use a free port on the server.
APP_PORT=8082

# ─── Elasticsearch JVM heap (adjust based on available RAM) ───
ES_JAVA_OPTS=-Xms1g -Xmx1g
